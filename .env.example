# ---------------------------------------------------------------------------
# tutor-finance — environment variables
# Copy to .env and fill in. Defaults match docker/docker-compose.yml.
# ---------------------------------------------------------------------------

NODE_ENV=development

# --- App URLs ---------------------------------------------------------------
BETTER_AUTH_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:4321
PUBLIC_API_URL=http://localhost:3000
# SERVER_API_URL: used by Astro SSR for server-side API calls.
# On Render, set to the internal URL (e.g. https://tutor-finance-api.onrender.com).
# Falls back to PUBLIC_API_URL when unset (fine for local dev).
SERVER_API_URL=

# API_PORT: overrides PORT for local development (Render injects PORT automatically).
API_PORT=3000

# --- Postgres --------------------------------------------------------------
POSTGRES_USER=tutor
POSTGRES_PASSWORD=tutor
POSTGRES_DB=tutor_finance
DATABASE_URL=postgres://tutor:tutor@localhost:5432/tutor_finance

# --- Better Auth -----------------------------------------------------------
# 32+ random bytes. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-random-32-bytes-or-more

# --- Email -----------------------------------------------------------------
# AUTH_EMAIL_PROVIDER: smtp | resend
AUTH_EMAIL_PROVIDER=smtp
MAIL_FROM="Uchetka <noreply@tutor-finance.local>"

# SMTP (used when AUTH_EMAIL_PROVIDER=smtp)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Resend (used when AUTH_EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# --- Auth cookies ----------------------------------------------------------
# Set to true when API and web are on different domains (e.g. Render without custom domain).
# Switch to false once both services share a domain/subdomain.
CROSS_ORIGIN_COOKIES=false

# --- FX rates --------------------------------------------------------------
# exchangerate.host has moved to a paid model; set a working endpoint if needed.
# Free alternative: https://open.er-api.com/v6/latest (requires URL format change in fx.service.ts)
FX_API_URL=https://api.exchangerate.host/latest
