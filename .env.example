# ---------------------------------------------------------------------------
# tutor-finance — environment variables
# Copy to .env and fill in. Defaults below are dev-friendly (docker-compose).
# ---------------------------------------------------------------------------

NODE_ENV=development

# --- App URLs ---------------------------------------------------------------
# Public origin where Caddy serves both web + api in production.
# In dev (pnpm dev), web runs on 4321 and api on 3000 directly.
BETTER_AUTH_URL=http://localhost:4321
PUBLIC_APP_URL=http://localhost:4321
PUBLIC_API_URL=http://localhost:3000

# --- MongoDB ---------------------------------------------------------------
# Replica set is required for Better Auth transaction support.
DATABASE_URL=mongodb://localhost:27017/tutor_finance?replicaSet=rs0&directConnection=true

# --- Better Auth -----------------------------------------------------------
# 32+ random bytes. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-random-32-bytes-or-more

# --- Email -----------------------------------------------------------------
# AUTH_EMAIL_PROVIDER: smtp | resend
AUTH_EMAIL_PROVIDER=smtp
MAIL_FROM="Tutor Finance <noreply@tutor-finance.local>"

# SMTP (used when AUTH_EMAIL_PROVIDER=smtp). Defaults point at Mailhog.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Resend (used when AUTH_EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# --- MinIO / S3 (receipts — deferred feature, service runs from day 1) -----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=tutor-finance
S3_REGION=us-east-1

# --- FX rates --------------------------------------------------------------
FX_API_URL=https://api.exchangerate.host/latest
