---
import { createTranslator, normalizeLocale } from '@/lib/i18n';

const locale = normalizeLocale(Astro.currentLocale);
const t = createTranslator(locale);
const webUrl = import.meta.env.PUBLIC_WEB_URL ?? 'http://localhost:4321';
const githubUrl = 'https://github.com/Raiden0456/tutor-finance';
---

<section class="relative overflow-hidden">
  <!-- Background gradient blobs -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
    <div
      class="absolute -top-24 left-1/2 h-[480px] w-[480px] -translate-x-1/2 rounded-full bg-tf-indigo/20 blur-3xl"
    >
    </div>
    <div class="absolute -right-24 top-32 h-[320px] w-[320px] rounded-full bg-tf-teal/15 blur-3xl">
    </div>
    <div class="absolute -left-24 top-48 h-[300px] w-[300px] rounded-full bg-tf-coral/10 blur-3xl">
    </div>
  </div>

  <div class="mx-auto w-full max-w-6xl px-4 pb-12 pt-12 md:px-6 md:pb-20 md:pt-20">
    <div class="reveal flex flex-col items-center text-center">
      <span
        class="mb-5 inline-flex items-center gap-2 rounded-full border border-border bg-card px-3 py-1 text-xs font-medium text-muted-foreground shadow-sm"
      >
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-tf-jade"></span>
        {t('Open beta')}
      </span>

      <h1 class="max-w-3xl text-balance text-4xl font-bold tracking-tight md:text-6xl">
        {t('Know what your tutoring actually earns.')}
      </h1>

      <p class="mt-5 max-w-2xl text-balance text-base text-muted-foreground md:text-lg">
        {t('Lessons, students, payments and expenses in one place — across any currency.')}
      </p>

      <div
        class="mt-7 flex w-full flex-col items-center justify-center gap-3 sm:w-auto sm:flex-row"
      >
        <a
          href={`${webUrl}/sign-up`}
          class="inline-flex h-11 w-full items-center justify-center rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground transition-all duration-200 hover:bg-primary/90 active:scale-95 sm:w-auto"
        >
          {t('Try the beta')}
        </a>
        <a
          href={githubUrl}
          target="_blank"
          rel="noreferrer"
          class="inline-flex h-11 w-full items-center justify-center gap-2 rounded-md border border-border bg-card px-6 text-sm font-medium text-foreground shadow-sm transition-all duration-200 hover:bg-accent active:scale-95 sm:w-auto"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" aria-hidden="true">
            <path
              fill="currentColor"
              d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
            ></path>
          </svg>
          {t('View on GitHub')}
        </a>
      </div>
    </div>

    <div class="reveal mt-12 md:mt-16" style="animation-delay: 120ms">
      <div
        class="relative mx-auto max-w-5xl overflow-hidden rounded-2xl border border-border bg-card shadow-2xl shadow-tf-indigo/10"
      >
        <img
          src="/og.png"
          alt={t('Uchetka dashboard preview')}
          class="block h-auto w-full"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
