---
import AppLayout from '@/layouts/AppLayout.astro';
import { StudentsIsland } from '@/islands/students-island';
import { serverApi } from '@/lib/api';
import type { Currency } from '@tutor-finance/shared';
import type { Student, IncomeTx } from '@/lib/types';

const cookie = Astro.request.headers.get('cookie') ?? undefined;
const api = serverApi(cookie);

const settings = await api.get<{ primaryCurrency: Currency }>('/settings/me');
const primary: Currency = settings.primaryCurrency ?? 'USD';

const now = new Date();
const from = new Date(now.getFullYear(), now.getMonth(), 1);
const to = new Date(now.getFullYear(), now.getMonth() + 1, 0, 23, 59, 59);

const [students, transactions] = await Promise.all([
  api.get<Student[]>('/students'),
  api.get<IncomeTx[]>('/transactions', {
    query: {
      type: 'income',
      from: from.toISOString(),
      to: to.toISOString(),
      limit: 1000,
      target: primary,
    },
  }),
]);
---

<AppLayout title="Students">
  <StudentsIsland
    client:load
    initial={students}
    transactions={transactions}
    primaryCurrency={primary}
  />
</AppLayout>
