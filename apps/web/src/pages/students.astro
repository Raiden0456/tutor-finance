---
import AppLayout from '@/layouts/AppLayout.astro';
import { StudentsIsland } from '@/islands/students-island';
import { serverApi } from '@/lib/api';
import type { Currency } from '@tutor-finance/shared';

interface Student {
  id: string;
  name: string;
  email?: string | null;
  phone?: string | null;
  hourlyRate: { amount: number; currency: Currency };
  defaultCurrency: Currency;
  notes?: string | null;
  archivedAt?: string | null;
}

const cookie = Astro.request.headers.get('cookie') ?? undefined;
const students = await serverApi(cookie).get<Student[]>('/students');
---
<AppLayout title="Students">
  <StudentsIsland client:load initial={students} />
</AppLayout>
