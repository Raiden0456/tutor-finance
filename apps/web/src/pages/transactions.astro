---
import AppLayout from '@/layouts/AppLayout.astro';
import { TransactionsIsland } from '@/islands/transactions-island';
import { getServerClient } from '@/lib/apollo';
import { Q_ME_SETTINGS, Q_TRANSACTIONS } from '@/lib/gql';

const cookie = Astro.request.headers.get('cookie') ?? undefined;
const client = getServerClient({ cookie });

const settingsRes = await client.query({ query: Q_ME_SETTINGS });
const primary = settingsRes.data?.mySettings?.primaryCurrency ?? 'USD';

const txRes = await client.query({
  query: Q_TRANSACTIONS,
  variables: { filter: { limit: 200 }, target: primary },
});
---
<AppLayout title="Transactions">
  <TransactionsIsland
    client:load
    initial={txRes.data?.transactions ?? []}
    primaryCurrency={primary}
  />
</AppLayout>
