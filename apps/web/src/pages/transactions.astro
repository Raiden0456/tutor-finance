---
import AppLayout from '@/layouts/AppLayout.astro';
import { TransactionsIsland } from '@/islands/transactions-island';
import { serverApi } from '@/lib/api';
import type { Currency } from '@tutor-finance/shared';
import type { Tx, Recurring, Summary } from '@/lib/types';

const cookie = Astro.request.headers.get('cookie') ?? undefined;
const api = serverApi(cookie);

const settings = await api.get<{ primaryCurrency: Currency }>('/settings/me');
const primary: Currency = settings.primaryCurrency ?? 'USD';

const now = new Date();
const to = new Date(now);
to.setHours(23, 59, 59, 999);
const from = new Date(now);
from.setDate(from.getDate() - 29);
from.setHours(0, 0, 0, 0);

const [transactions, recurring, summary] = await Promise.all([
  api.get<Tx[]>('/transactions', {
    query: { limit: 1000, target: primary, from: from.toISOString(), to: to.toISOString() },
  }),
  api.get<Recurring[]>('/recurring'),
  api.get<Summary>('/dashboard/summary', {
    query: { from: from.toISOString(), to: to.toISOString(), target: primary },
  }),
]);
---

<AppLayout title="Transactions">
  <TransactionsIsland
    client:load
    initial={transactions}
    primaryCurrency={primary}
    initialRecurring={recurring}
    initialSummary={summary}
  />
</AppLayout>
