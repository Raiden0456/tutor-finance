---
import AuthLayout from '@/layouts/AuthLayout.astro';
import { ResetPasswordForm } from '@/islands/reset-password-form';
import { createTranslator, normalizeLocale } from '@/lib/i18n';

const locale = normalizeLocale(Astro.currentLocale);
const t = createTranslator(locale);
---

<AuthLayout
  title={t('Reset password')}
  description={t('Set a new password for your Uchetka tutor finance dashboard.')}
>
  <ResetPasswordForm locale={locale} client:load />
</AuthLayout>
