---
import AppLayout from '@/layouts/AppLayout.astro';
import { LessonsIsland } from '@/islands/lessons-island';
import { serverApi } from '@/lib/api';

interface Lesson {
  id: string;
  studentId: string;
  startsAt: string;
  durationMin: number;
  status: 'scheduled' | 'completed' | 'cancelled' | 'no_show';
  notes?: string | null;
}

const cookie = Astro.request.headers.get('cookie') ?? undefined;
const api = serverApi(cookie);

const [lessons, studentsList] = await Promise.all([
  api.get<Lesson[]>('/lessons', { query: { limit: 200 } }),
  api.get<{ id: string; name: string }[]>('/students'),
]);

const students = studentsList.map((s) => ({ id: s.id, name: s.name }));
---
<AppLayout title="Lessons">
  <LessonsIsland client:load initial={lessons} students={students} />
</AppLayout>
