---
import AppLayout from '@/layouts/AppLayout.astro';
import { LessonsIsland } from '@/islands/lessons-island';
import { serverApi } from '@/lib/api';
import { createTranslator, normalizeLocale } from '@/lib/i18n';
import type { Lesson, RecurringLesson, Settings, Student } from '@/lib/types';

const cookie = Astro.request.headers.get('cookie') ?? undefined;
const api = serverApi(cookie);
const locale = normalizeLocale(Astro.currentLocale);
const t = createTranslator(locale);

const now = new Date();
const monthStart = new Date(now.getFullYear(), now.getMonth(), 1);
const monthEnd = new Date(now.getFullYear(), now.getMonth() + 1, 0, 23, 59, 59, 999);
const initialMonthStr = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;

const [settings, lessons, studentsList, schedulesList] = await Promise.all([
  api.get<Settings>('/settings/me'),
  api.get<Lesson[]>('/lessons', {
    query: {
      from: monthStart.toISOString(),
      to: monthEnd.toISOString(),
      limit: 500,
      orderDir: 'asc',
    },
  }),
  api.get<Student[]>('/students'),
  api.get<RecurringLesson[]>('/recurring-lessons'),
]);

const students = studentsList.map((s) => ({ id: s.id, name: s.name, meetingLink: s.meetingLink }));
---

<AppLayout
  title={t('Lessons')}
  description={t(
    'Plan, track, and archive tutor lessons with statuses, payments, homework, and meeting links.',
  )}
>
  <LessonsIsland
    client:load
    initial={lessons}
    students={students}
    initialMonthStr={initialMonthStr}
    weekStartsOn={settings.weekStartsOn}
    locale={locale}
    initialSchedules={schedulesList}
  />
</AppLayout>
