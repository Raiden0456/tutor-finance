---
import AuthLayout from '@/layouts/AuthLayout.astro';
import { LoginForm } from '@/islands/login-form';
import { getServerSession } from '@/lib/auth-server';

const cookie = Astro.request.headers.get('cookie') ?? undefined;
const session = await getServerSession(cookie);
if (session.user) {
  return Astro.redirect('/');
}
---

<AuthLayout
  title="Sign in"
  description="Sign in to Uchetka, an Open-source finance tracker for tutors. Track lessons, students, payments, and income without spreadsheet hell."
  wide
>
  <LoginForm client:load />
</AuthLayout>
