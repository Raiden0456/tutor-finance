---
import AppLayout from '@/layouts/AppLayout.astro';
import { DashboardIsland } from '@/islands/dashboard-island';
import { serverApi } from '@/lib/api';
import type { Summary, RecentLesson, DailyTx } from '@/lib/types';

const cookie = Astro.request.headers.get('cookie') ?? undefined;
const api = serverApi(cookie);

const now = new Date();
const from = new Date(now.getFullYear(), now.getMonth(), 1);
const to = new Date(now.getFullYear(), now.getMonth() + 1, 0, 23, 59, 59);

const summary = await api.get<Summary>('/dashboard/summary', {
  query: { from: from.toISOString(), to: to.toISOString() },
});

const recentLessons = await api.get<RecentLesson[]>('/lessons', { query: { limit: 5 } });

const studentsList = await api.get<{ id: string; name: string }[]>('/students', {
  query: { includeArchived: true },
});
const studentNames: Record<string, string> = {};
for (const s of studentsList) studentNames[s.id] = s.name;

const dailyTransactions = await api.get<DailyTx[]>('/transactions', {
  query: {
    from: from.toISOString(),
    to: to.toISOString(),
    limit: 1000,
    target: summary.targetCurrency,
  },
});
---

<AppLayout title="Dashboard">
  <DashboardIsland
    client:load
    summary={summary}
    recentLessons={recentLessons}
    studentNames={studentNames}
    dailyTransactions={dailyTransactions}
  />
</AppLayout>
