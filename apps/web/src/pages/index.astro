---
import AppLayout from '@/layouts/AppLayout.astro';
import { DashboardIsland } from '@/islands/dashboard-island';
import { serverApi } from '@/lib/api';
import { createTranslator, normalizeLocale } from '@/lib/i18n';
import type { Summary, RecentLesson } from '@/lib/types';

const cookie = Astro.request.headers.get('cookie') ?? undefined;
const api = serverApi(cookie);
const locale = normalizeLocale(Astro.currentLocale);
const t = createTranslator(locale);

const now = new Date();

// 7-day range for summary (matches the island's default preset)
const to = new Date(now);
to.setHours(23, 59, 59, 999);
const from = new Date(now);
from.setDate(from.getDate() - 6);
from.setHours(0, 0, 0, 0);

// Today's date bounds
const todayStart = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 0, 0, 0);
const todayEnd = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 23, 59, 59, 999);

const [summary, todayLessons, nextLessonList, studentsList] = await Promise.all([
  api.get<Summary>('/dashboard/summary', {
    query: { from: from.toISOString(), to: to.toISOString() },
  }),
  api.get<RecentLesson[]>('/lessons', {
    query: {
      from: todayStart.toISOString(),
      to: todayEnd.toISOString(),
      orderDir: 'asc',
      limit: 20,
    },
  }),
  api.get<RecentLesson[]>('/lessons', {
    query: { status: 'scheduled', from: now.toISOString(), orderDir: 'asc', limit: 1 },
  }),
  api.get<{ id: string; name: string }[]>('/students', {
    query: { includeArchived: true },
  }),
]);
const nextLesson = nextLessonList[0] ?? null;
const studentNames: Record<string, string> = {};
for (const s of studentsList) studentNames[s.id] = s.name;
---

<AppLayout
  title={t('Dashboard')}
  description={t(
    'Your tutor finance dashboard: upcoming lessons, daily stats, recent income, and student activity at a glance.',
  )}
>
  <DashboardIsland
    client:load
    summary={summary}
    nextLesson={nextLesson}
    todayLessons={todayLessons}
    studentNames={studentNames}
    locale={locale}
  />
</AppLayout>
