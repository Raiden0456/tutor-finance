---
import AuthLayout from '@/layouts/AuthLayout.astro';
import { ForgotPasswordForm } from '@/islands/forgot-password-form';
import { createTranslator, normalizeLocale } from '@/lib/i18n';

const locale = normalizeLocale(Astro.currentLocale);
const t = createTranslator(locale);
---

<AuthLayout
  title={t('Forgot password?')}
  description={t('Reset access to your Uchetka tutor finance dashboard.')}
>
  <ForgotPasswordForm locale={locale} client:load />
</AuthLayout>
