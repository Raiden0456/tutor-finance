---
import AppLayout from '@/layouts/AppLayout.astro';
import { SettingsIsland } from '@/islands/settings-island';
import { getServerClient } from '@/lib/apollo';
import { Q_ME_SETTINGS } from '@/lib/gql';

const cookie = Astro.request.headers.get('cookie') ?? undefined;
const client = getServerClient({ cookie });
const { data } = await client.query({ query: Q_ME_SETTINGS });
const initial = data?.mySettings ?? { primaryCurrency: 'USD', theme: 'system', locale: 'en' };
---
<AppLayout title="Settings">
  <h1 class="mb-4 text-xl font-semibold">Settings</h1>
  <SettingsIsland client:load initial={initial} />
</AppLayout>
