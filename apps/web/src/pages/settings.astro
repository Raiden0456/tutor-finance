---
import AppLayout from '@/layouts/AppLayout.astro';
import { SettingsIsland } from '@/islands/settings-island';
import { serverApi } from '@/lib/api';
import type { Settings } from '@/lib/types';

const cookie = Astro.request.headers.get('cookie') ?? undefined;
const initial = await serverApi(cookie).get<Settings>('/settings/me');
---

<AppLayout title="Settings">
  <SettingsIsland client:load initial={initial} />
</AppLayout>
