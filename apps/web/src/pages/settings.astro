---
import AppLayout from '@/layouts/AppLayout.astro';
import { SettingsIsland } from '@/islands/settings-island';
import { serverApi } from '@/lib/api';
import type { Currency } from '@tutor-finance/shared';

interface SettingsData {
  primaryCurrency: Currency;
  theme: 'light' | 'dark' | 'system';
  locale: 'en' | 'ru';
}

const cookie = Astro.request.headers.get('cookie') ?? undefined;
const initial = await serverApi(cookie).get<SettingsData>('/settings/me');
---
<AppLayout title="Settings">
  <h1 class="mb-4 text-xl font-semibold">Settings</h1>
  <SettingsIsland client:load initial={initial} />
</AppLayout>
