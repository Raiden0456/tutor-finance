---
import '@/styles/globals.css';
import { ClientRouter } from 'astro:transitions';
import Seo from '@/components/seo.astro';
import { Sidebar, MobileTabBar } from '@/components/nav';
import { ThemeToggle } from '@/components/theme-toggle';
import { SignOutButton } from '@/components/sign-out-button';
import { LanguageSwitcher } from '@/components/language-switcher';
import { MobilePushBridge } from '@/components/mobile-push-bridge';
import { PageSkeleton } from '@/components/page-skeleton';
import { getServerSession } from '@/lib/auth-server';
import { normalizeLocale } from '@/lib/i18n';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Uchetka', description } = Astro.props;
const cookie = Astro.request.headers.get('cookie') ?? undefined;
const session = await getServerSession(cookie);
const url = new URL(Astro.request.url);
const path = url.pathname;
const switcherPath = `${url.pathname}${url.search}`;
const locale = normalizeLocale(Astro.currentLocale);
const themeCookie = (Astro.cookies.get('theme')?.value ?? 'system') as 'light' | 'dark' | 'system';
const nativeShell =
  Astro.request.headers.get('user-agent')?.includes('TutorFinanceNativeShell/1.0') ?? false;
const userDisplayName = session.user?.name || session.user?.email;
---

<!doctype html>
<html lang={locale} data-native-shell={nativeShell ? 'true' : undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#faf4ed" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#111113" media="(prefers-color-scheme: dark)" />
    <Seo title={title} description={description} noindex />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Onest:wght@100..900&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
    <style is:inline>
      :root {
        --app-safe-area-top: env(safe-area-inset-top);
      }

      html[data-native-shell='true'] {
        --app-safe-area-top: 0px;
      }
    </style>
    <script is:inline>
      if (window.__TUTOR_FINANCE_NATIVE_SHELL__ || window.ReactNativeWebView) {
        document.documentElement.setAttribute('data-native-shell', 'true');
      }
    </script>
    <script is:inline>
      // Bridge Astro view-transition events into React Native WebView so the
      // mobile shell can clear its loading overlay (pushState-style navigations
      // don't fire WebView.onLoadEnd).
      (function () {
        function post(type) {
          try {
            if (window.ReactNativeWebView) {
              window.ReactNativeWebView.postMessage(JSON.stringify({ type: type }));
            }
          } catch (_) {}
        }
        document.addEventListener('astro:before-preparation', function () {
          post('astro:before-preparation');
        });
        document.addEventListener('astro:after-swap', function () {
          post('astro:after-swap');
        });
        document.addEventListener('astro:page-load', function () {
          post('astro:page-load');
        });
      })();
    </script>
    <script is:inline>
      (function () {
        function apply() {
          try {
            var t = localStorage.getItem('theme') || 'system';
            document.cookie = 'theme=' + t + ';path=/;max-age=31536000;samesite=lax';
            var dark =
              t === 'dark' ||
              (t === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
            document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
          } catch (_) {}
        }
        apply();
        document.addEventListener('astro:after-swap', apply);
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <div class="flex min-h-screen">
      <Sidebar current={path} locale={locale} initialTheme={themeCookie} client:load />
      <div class="flex min-w-0 flex-1 flex-col">
        <!-- Mobile header -->
        <header
          id="mobile-header"
          class="sticky top-0 z-30 flex min-h-14 items-center justify-between px-4 duration-200 bg-card/80 backdrop-blur-md md:hidden"
          style="padding-top: var(--app-safe-area-top)"
        >
          <h1 class="text-2xl font-bold">{title}</h1>
          <div class="flex items-center gap-2">
            <LanguageSwitcher current={switcherPath} locale={locale} />
            <ThemeToggle initialTheme={themeCookie} variant="button" locale={locale} client:load />
          </div>
        </header>
        <!-- Desktop header -->
        <header
          class="sticky top-0 z-30 hidden min-h-14 items-center justify-end border-b border-border bg-card/80 px-6 backdrop-blur-md md:flex"
          style="padding-top: var(--app-safe-area-top)"
        >
          <div class="flex items-center gap-1">
            <span
              class="max-w-48 truncate text-sm text-muted-foreground transition-colors duration-200"
            >
              {userDisplayName}
            </span>
            <SignOutButton locale={locale} client:load />
          </div>
        </header>
        <main class="flex-1 px-4 pb-28 pt-5 md:px-8 md:pb-8 md:pt-6">
          <div class="mx-auto w-full max-w-3xl md:max-w-4xl">
            <slot />
          </div>
        </main>
      </div>
    </div>
    <MobilePushBridge client:load />
    <MobileTabBar current={path} locale={locale} client:load />
    <PageSkeleton client:load transition:persist />
  </body>
</html>
