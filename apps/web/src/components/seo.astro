---
import { PUBLIC_APP_URL } from '@/lib/env';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
}

const appName = 'Uchetka';
const defaultDescription =
  'Open-source finance tracker for tutors: lessons, students, payments, and income in one clean dashboard.';

const {
  title = appName,
  description = defaultDescription,
  image = '/og.png',
  canonicalPath = Astro.url.pathname,
  noindex = false,
  type = 'website',
} = Astro.props;

const pageTitle = title === appName ? appName : `${title} · ${appName}`;
const canonicalUrl = new URL(canonicalPath, PUBLIC_APP_URL).toString();
const imageUrl = new URL(image, PUBLIC_APP_URL).toString();
const locale = Astro.currentLocale === 'ru' ? 'ru_RU' : 'en_US';
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<link rel="canonical" href={canonicalUrl} />

<meta property="og:type" content={type} />
<meta property="og:site_name" content={appName} />
<meta property="og:locale" content={locale} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:secure_url" content={imageUrl} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={`${appName} finance tracker preview`} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
