{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV", "CI"],
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "POSTGRES_USER",
    "POSTGRES_PASSWORD",
    "POSTGRES_DB",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "PUBLIC_API_URL",
    "PUBLIC_APP_URL",
    "TRUSTED_ORIGINS",
    "AUTH_EMAIL_PROVIDER",
    "RESEND_API_KEY",
    "MAIL_FROM",
    "SMTP_HOST",
    "SMTP_PORT",
    "SMTP_USER",
    "SMTP_PASS",
    "SMTP_SECURE",
    "SERVER_API_URL",
    "REDIS_URL",
    "CACHE_ENABLED",
    "FX_API_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".astro/**", "build/**"],
      "env": ["PUBLIC_API_URL", "PUBLIC_APP_URL"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
