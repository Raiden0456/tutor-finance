# Expo packages reach internal modules (e.g. expo-modules-core) via hoisting.
# pnpm's strict isolation hides these from each other, which breaks `tsc`
# type resolution (Metro/autolinking handle it at build time on SDK 54+).
# Hoisting the Expo runtime to the root node_modules keeps type-checking green.
public-hoist-pattern[]=*expo-modules-core*
public-hoist-pattern[]=expo
